        "\n",
        "    cam, outputs, pred_class = gradcam(input_tensor)\n",
        "    probs = torch.softmax(outputs, dim=1).squeeze(0).cpu()\n",
        "\n",
        "    pred_name = classes[pred_class]\n",
        "    true_name = classes[true_label]\n",
        "    confidence = float(probs[pred_class])\n",
