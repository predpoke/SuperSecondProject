        "\n",
        "            try:\n",
        "                with Image.open(image_path) as img:\n",
        "                    img.verify()\n",
        "\n",
        "                rows.append({\n",
        "                    \"image_path\": image_path,\n",
        "                    \"filename\": filename,\n",
        "                    \"class_name\": class_name,\n",
        "                    \"label\": label\n",
