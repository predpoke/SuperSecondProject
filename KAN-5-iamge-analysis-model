        "        )\n",
        "        print(\"scheduler 재설정 완료\")\n",
        "\n",
        "        phase_changed = True\n",
        "\n",
        "        # phase 전환 직후 early stopping 카운터는 리셋\n",
        "        epochs_no_improve = 0\n",
        "        print(\"Phase 전환으로 epochs_no_improve 초기화\")\n",
