        "\n",
        "    top3_sum = 0.0\n",
        "    batch_count = 0\n",
        "\n",
        "    all_preds = []\n",
        "    all_labels = []\n",
        "\n",
        "    start_time = time.time()\n",
        "\n",
        "    progress_bar = tqdm(val_loader, desc=\"Validation\", leave=True)\n",
        "\n",
        "    with torch.no_grad():\n",
        "        for batch_idx, (images, labels) in enumerate(progress_bar):\n",
