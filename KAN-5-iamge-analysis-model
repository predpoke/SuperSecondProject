        "def analyze_full_validation_attention(\n",
        "    model,\n",
        "    val_loader,\n",
        "    classes,\n",
        "    device,\n",
        "    max_samples=None\n",
        "):\n",
        "    model.eval()\n",
        "\n",
        "    # ConvNeXt-Tiny 기준\n",
        "    target_layer = model.features[-1]\n",
        "    gradcam = GradCAM(model, target_layer)\n",
        "\n",
        "    rows = []\n",
        "    sample_idx = 0\n",
        "\n",
        "    for batch in tqdm(val_loader, desc=\"Full validation attention analysis\"):\n",
        "        images, labels = batch\n",
        "\n",
        "        for i in range(images.size(0)):\n",
        "            if max_samples is not None and sample_idx >= max_samples:\n",
        "                gradcam.remove_hooks()\n",
        "                return pd.DataFrame(rows)\n",
        "\n",
        "            image_tensor = images[i]\n",
        "            true_label = int(labels[i].item())\n",
        "\n",
        "            input_tensor = image_tensor.unsqueeze(0).to(device)\n",
        "\n",
        "            try:\n",
        "                cam, outputs, pred_class = gradcam(input_tensor)\n",
        "\n",
        "                diag = prediction_diagnostics(outputs, true_label)\n",
        "                cam_stats = cam_spatial_stats(cam)\n",
        "\n",
        "                pred_idx = diag[\"pred_idx\"]\n",
        "\n",
        "                row = {\n",
        "                    \"sample_idx\": sample_idx,\n",
        "\n",
        "                    \"true_idx\": true_label,\n",
        "                    \"true_label\": classes[true_label],\n",
        "\n",
        "                    \"pred_idx\": pred_idx,\n",
        "                    \"pred_label\": classes[pred_idx],\n",
        "\n",
        "                    \"is_correct\": int(pred_idx == true_label),\n",
        "\n",
        "                    \"confidence\": diag[\"confidence\"],\n",
        "                    \"true_prob\": diag[\"true_prob\"],\n",
        "                    \"true_rank\": diag[\"true_rank\"],\n",
        "\n",
        "                    \"top1\": classes[diag[\"top1_idx\"]],\n",
        "                    \"top1_prob\": diag[\"top1_prob\"],\n",
        "\n",
        "                    \"top2\": classes[diag[\"top2_idx\"]],\n",
        "                    \"top2_prob\": diag[\"top2_prob\"],\n",
        "\n",
        "                    \"top3\": classes[diag[\"top3_idx\"]],\n",
        "                    \"top3_prob\": diag[\"top3_prob\"],\n",
        "\n",
        "                    \"margin_top1_top2\": diag[\"margin_top1_top2\"],\n",
        "                    \"entropy\": diag[\"entropy\"],\n",
        "                }\n",
        "\n",
        "                row.update(cam_stats)\n",
        "                rows.append(row)\n",
        "\n",
        "            except Exception as e:\n",
        "                print(\"분석 실패:\", sample_idx, e)\n",
        "\n",
        "            sample_idx += 1\n",
        "\n",
        "    gradcam.remove_hooks()\n",
        "\n",
        "    return pd.DataFrame(rows)"
      ]
    },
