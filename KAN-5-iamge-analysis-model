        "            attention_df[\"cam_top10_energy\"].tolist()\n",
        "        ],\n",
        "        keys=[\"Center energy\", \"Top 10% energy\"],\n",
        "        title=\"Grad-CAM attention concentration\",\n",
        "        xname=\"Sample index\"\n",
        "    )\n",
        "})\n",
        "\n",
        "wandb.finish()"
      ]
