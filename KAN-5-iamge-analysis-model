      "source": [
        "# 이미 학습이 끝난 상태에서\n",
        "# Grad-CAM / confidence / entropy / margin / CAM 수치 그래프를 W&B에 올리는 코드\n",
        "\n",
        "\n",
        "#여기부터는 만들었다기 보다는 내 의견을 가지고 GPT가 해석한 경향성이 큰 코드들임\n",
        "\n",
        "import wandb\n",
        "\n",
        "run = wandb.init(\n",
        "    project=\"officehome-product-classification\",\n",
        "    name=\"convnext-posthoc-attention-graph\",\n",
        "    group=\"attention_analysis\",\n",
        "    job_type=\"posthoc_gradcam_diagnostics\",\n",
        "    config={\n",
        "        \"model\": \"convnext_tiny\",\n",
        "        \"analysis\": \"posthoc_attention_diagnostics\"\n",
        "    }\n",
        ")\n",
        "\n",
        "# attention_df가 이미 만들어져 있다고 가정\n",
        "# 없으면 먼저 analyze_model_attention(...)으로 생성 필요\n",
        "\n",
        "wandb.log({\n",
        "    \"attention/diagnostics_table\": wandb.Table(dataframe=attention_df),\n",
        "\n",
        "    \"attention/confidence_vs_true_prob\": wandb.plot.line_series(\n",
        "        xs=attention_df[\"sample_idx\"].tolist(),\n",
        "        ys=[\n",
        "            attention_df[\"confidence\"].tolist(),\n",
        "            attention_df[\"true_prob\"].tolist()\n",
        "        ],\n",
        "        keys=[\"Prediction confidence\", \"True class probability\"],\n",
        "        title=\"Prediction confidence vs true class probability\",\n",
        "        xname=\"Sample index\"\n",
        "    ),\n",
        "\n",
        "    \"attention/entropy\": wandb.plot.bar(\n",
        "        wandb.Table(\n",
        "            dataframe=attention_df[[\"sample_idx\", \"entropy\"]]\n",
        "        ),\n",
        "        \"sample_idx\",\n",
        "        \"entropy\",\n",
        "        title=\"Prediction uncertainty entropy\"\n",
        "    ),\n",
        "\n",
        "    \"attention/top1_top2_margin\": wandb.plot.bar(\n",
        "        wandb.Table(\n",
        "            dataframe=attention_df[[\"sample_idx\", \"margin_top1_top2\"]]\n",
        "        ),\n",
        "        \"sample_idx\",\n",
        "        \"margin_top1_top2\",\n",
        "        title=\"Decision margin: Top1 - Top2 probability\"\n",
        "    ),\n",
        "\n",
