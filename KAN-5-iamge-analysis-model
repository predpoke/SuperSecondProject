        "\n",
        "                \"true_label\": true_name,\n",
        "                \"pred_label\": pred_name,\n",
        "                \"is_correct\": int(diag[\"pred_idx\"] == true_label),\n",
        "\n",
        "                \"confidence\": diag[\"confidence\"],\n",
