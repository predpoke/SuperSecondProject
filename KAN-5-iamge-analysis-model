        "class RandomBottomMask :\n",
        "  def __init__(self, p=0.3, max_height_ratio = 0.25, alpha=0.5):\n",
        "    self.p = p\n",
        "    self.max_height_ratio = max_height_ratio\n",
        "    self.alpha = alpha\n",
        "\n",
        "  def __call__(self, image):\n",
        "    if random.random() > self.p :\n",
        "      return image\n",
        "\n",
        "    img = np.array(image.convert(\"RGB\")).astype(np.float32)\n",
        "    h, w, c = img.shape\n",
        "\n",
        "    mask_h = int(h * random.uniform(0.08, self.max_height_ratio))\n",
        "    y1 = h - mask_h\n",
        "\n",
        "    mean_color = img.mean(axis=(0, 1), keepdims=True)\n",
        "\n",
        "    img[y1:h, :, :] = (\n",
        "        self.alpha * img[y1:h, :, :] +\n",
        "        (1 - self.alpha) * mean_color\n",
        "    )\n",
        "\n",
        "    img = np.clip(img, 0, 255).astype(np.uint8)\n",
        "\n",
        "    return Image.fromarray(img)\n"
