        "\n",
        "                \"top3\": classes[diag[\"top3_idx\"]],\n",
        "                \"top3_prob\": diag[\"top3_prob\"],\n",
        "\n",
        "                \"margin_top1_top2\": diag[\"margin_top1_top2\"],\n",
        "                \"entropy\": diag[\"entropy\"],\n",
        "\n",
        "                \"cam_center_energy\": cam_stats[\"cam_center_energy\"],\n",
        "                \"cam_top10_energy\": cam_stats[\"cam_top10_energy\"],\n",
        "                \"cam_mean\": cam_stats[\"cam_mean\"],\n",
        "                \"cam_max\": cam_stats[\"cam_max\"],\n",
        "            })\n",
        "\n",
        "            if use_wandb:\n",
        "                try:\n",
        "                    import wandb\n",
        "\n",
        "                    if wandb.run is not None:\n",
        "                        caption = (\n",
        "                            f\"TRUE: {true_name} | \"\n",
