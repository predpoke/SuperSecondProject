        "def topk_accuracy(outputs, labels, k=3):\n",
        "    with torch.no_grad():\n",
        "        _, topk_preds = outputs.topk(k, dim=1)\n",
        "        correct = topk_preds.eq(labels.view(-1, 1).expand_as(topk_preds))\n",
        "        return correct.any(dim=1).float().mean().item()"
      ]
    },
    {
