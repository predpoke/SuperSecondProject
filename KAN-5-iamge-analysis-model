        "\n",
        "        try:\n",
        "            cam, outputs, pred_class = gradcam(input_tensor)\n",
        "\n",
        "            diag = prediction_diagnostics(outputs, true_label)\n",
        "            cam_stats = cam_numeric_stats(cam)\n",
        "            overlay = make_gradcam_overlay(image_tensor, cam)\n",
        "\n",
        "            true_name = classes[true_label]\n",
        "            pred_name = classes[diag[\"pred_idx\"]]\n",
        "\n",
        "            rows.append({\n",
