      },
      "outputs": [],
      "source": [
        "grid_cols = [\n",
        "    \"grid_top_left\", \"grid_top_center\", \"grid_top_right\",\n",
        "    \"grid_middle_left\", \"grid_middle_center\", \"grid_middle_right\",\n",
        "    \"grid_bottom_left\", \"grid_bottom_center\", \"grid_bottom_right\"\n",
        "]\n",
        "\n",
        "grid_mean = attention_all_df[grid_cols].mean().sort_values(ascending=False)\n",
        "\n",
        "display(grid_mean)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "SnXExU2yKBiI"
      },
      "outputs": [],
      "source": [
        "grid_mean_matrix = np.array([\n",
        "    [\n",
        "        attention_all_df[\"grid_top_left\"].mean(),\n",
        "        attention_all_df[\"grid_top_center\"].mean(),\n",
        "        attention_all_df[\"grid_top_right\"].mean(),\n",
        "    ],\n",
        "    [\n",
        "        attention_all_df[\"grid_middle_left\"].mean(),\n",
        "        attention_all_df[\"grid_middle_center\"].mean(),\n",
        "        attention_all_df[\"grid_middle_right\"].mean(),\n",
        "    ],\n",
        "    [\n",
        "        attention_all_df[\"grid_bottom_left\"].mean(),\n",
        "        attention_all_df[\"grid_bottom_center\"].mean(),\n",
        "        attention_all_df[\"grid_bottom_right\"].mean(),\n",
        "    ],\n",
        "])\n",
        "\n",
        "grid_mean_df = pd.DataFrame(\n",
        "    grid_mean_matrix,\n",
        "    index=[\"Top\", \"Middle\", \"Bottom\"],\n",
        "    columns=[\"Left\", \"Center\", \"Right\"]\n",
        ")\n",
        "\n",
        "display(grid_mean_df)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "li5LmfETKCmq"
      },
      "outputs": [],
      "source": [
        "correct_grid = attention_all_df[attention_all_df[\"is_correct\"] == 1][grid_cols].mean()\n",
        "wrong_grid = attention_all_df[attention_all_df[\"is_correct\"] == 0][grid_cols].mean()\n",
        "\n",
        "grid_compare_df = pd.DataFrame({\n",
        "    \"correct_mean\": correct_grid,\n",
        "    \"wrong_mean\": wrong_grid,\n",
        "    \"wrong_minus_correct\": wrong_grid - correct_grid\n",
        "}).sort_values(\"wrong_minus_correct\", ascending=False)\n",
        "\n",
        "display(grid_compare_df)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "XIVFKT4-MVBQ"
      },
      "outputs": [],
      "source": [
        "bottom_wrong_samples = attention_all_df[\n",
        "    (attention_all_df[\"is_correct\"] == 0)\n",
        "].sort_values(\n",
        "    by=\"grid_bottom_center\",\n",
        "    ascending=False\n",
        ")\n",
        "\n",
        "display(bottom_wrong_samples.head(20))"
      ]
    },
