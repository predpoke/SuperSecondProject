        "    total = mask.sum()\n",
        "\n",
        "    if total == 0:\n",
        "      correct = 0\n",
        "      acc = 0.0\n",
        "\n",
        "    else :\n",
        "      correct = int((preds[mask] == labels[mask]).sum())\n",
        "      acc = correct/ total\n",
        "\n",
        "    rows.append({\n",
        "        \"class_idx\" : idx,\n",
        "        \"class_name\" : class_name,\n",
        "        \"total\" : int(total),\n",
        "        \"correct\" : int(correct),\n",
        "        \"accuracy\" : acc\n",
        "    })\n",
        "  return pd.DataFrame(rows).sort_values(\"accuracy\", ascending=True)"
      ]
