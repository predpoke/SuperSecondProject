        "import numpy as np\n",
        "import pandas as pd\n",
        "\n",
        "def make_class_recall_table(labels, preds, classes):\n",
        "    labels = np.array(labels)\n",
        "    preds = np.array(preds)\n",
        "\n",
        "    rows = []\n",
        "\n",
        "    for idx, class_name in enumerate(classes):\n",
        "        mask = labels == idx\n",
        "        total = int(mask.sum())\n",
        "\n",
        "        if total == 0:\n",
        "            correct = 0\n",
        "            recall = 0.0\n",
        "        else:\n",
        "            correct = int((preds[mask] == labels[mask]).sum())\n",
        "            recall = correct / total\n",
        "\n",
        "        rows.append({\n",
        "            \"class_idx\": idx,\n",
        "            \"class_name\": class_name,\n",
        "            \"total\": total,\n",
        "            \"correct\": correct,\n",
        "            \"recall\": recall\n",
        "        })\n",
        "\n",
        "    return pd.DataFrame(rows).sort_values(\"recall\", ascending=True)\n",
        "\n",
