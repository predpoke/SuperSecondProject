        "    )\n",
        "\n",
        "    overfit_gap = train_acc - val_acc\n",
        "    current_lr = optimizer.param_groups[0][\"lr\"]\n",
        "\n",
        "    print(\n",
        "        f\"\\nEpoch [{epoch + 1}/{epochs}] 결과\\n\"\n",
        "        f\"Train Loss: {train_loss:.4f} | Train Acc: {train_acc:.4f} |  Train Time: {train_time:.2f}초\\n\"\n",
        "        f\"Val Loss  : {val_loss:.4f} | Val Acc  : {val_acc:.4f} | Val Top3  : {val_top3:.4f} | Val Time  : {val_time:.2f}초\\n\"\n",
        "        f\"Overfit Gap: {overfit_gap:.4f} | LR: {current_lr}\"\n",
        "    )\n",
        "\n",
        "    history[\"epoch\"].append(epoch + 1)\n",
        "    history[\"train_loss\"].append(train_loss)\n",
        "    history[\"train_acc\"].append(train_acc)\n",
        "    history[\"train_time\"].append(train_time)\n",
        "\n",
        "    history[\"val_loss\"].append(val_loss)\n",
        "    history[\"val_acc\"].append(val_acc)\n",
        "    history[\"val_top3\"].append(val_top3)\n",
        "    history[\"val_time\"].append(val_time)\n",
        "\n",
        "    history[\"overfit_gap\"].append(overfit_gap)\n",
        "    history[\"lr\"].append(current_lr)\n",
        "\n",
        "    scheduler.step(val_acc)\n",
        "\n",
        "    if val_acc > best_val_acc:\n",
        "        best_val_acc = val_acc\n",
        "        best_epoch = epoch + 1\n",
        "        epochs_no_improve = 0\n",
        "\n",
        "        torch.save({\n",
        "            \"model_state_dict\": model.state_dict(),\n",
        "            \"classes\": classes,\n",
        "            \"class_to_idx\": class_to_idx,\n",
        "            \"val_acc\": best_val_acc,\n",
        "            \"epoch\": best_epoch,\n",
        "            \"num_classes\": num_classes,\n",
        "            \"model_name\": \"resnet18\",\n",
        "        }, save_path)\n",
        "\n",
        "        print(f\"Best model 저장 완료 | Epoch: {best_epoch} | Val Acc: {best_val_acc:.4f}\")\n",
        "\n",
        "    else:\n",
        "        epochs_no_improve += 1\n",
        "        print(f\"성능 개선 없음: {epochs_no_improve}/{patience}\")\n",
        "\n",
        "    scheduler.step(val_acc)\n",
        "\n",
        "     # Phase 2 전환 조건\n",
        "    if (train_acc >= phase_trigger_train_acc) and (not phase_changed):\n",
        "        print(\"\\n\" + \"=\" * 60)\n",
        "        print(f\"Phase 2 전환 조건 충족: train_acc={train_acc:.4f} >= {phase_trigger_train_acc}\")\n",
        "        print(\"학습 방식을 변경합니다.\")\n",
        "        print(\"=\" * 60)\n",
        "\n",
        "        # 1. train transform 변경\n",
        "        train_dataset.transform = phase2_train_transform\n",
        "        print(\"train_dataset transform을 Phase 2 transform으로 변경 완료\")\n",
        "\n",
        "        # 2. classifier dropout 추가\n",
        "        model = add_dropout_to_convnext_classifier(\n",
        "            model,\n",
        "            dropout_p=0.2\n",
        "        )\n",
        "        model = model.to(device)\n",
        "\n",
        "        # 3. backbone 일부 freeze\n",
        "        model = switch_to_phase2_convnext(model)\n",
        "\n",
        "        # 4. criterion 변경\n",
        "        criterion = nn.CrossEntropyLoss(label_smoothing=0.08)\n",
        "        print(\"criterion 변경: label_smoothing=0.08\")\n",
        "\n",
        "        # 5. optimizer 재설정\n",
        "        trainable_params = [\n",
        "            p for p in model.parameters()\n",
        "            if p.requires_grad\n",
        "        ]\n",
        "\n",
        "        optimizer = optim.AdamW(\n",
        "            trainable_params,\n",
        "            lr=5e-5,\n",
        "            weight_decay=1e-4\n",
        "        )\n",
        "        print(\"optimizer 변경: AdamW, lr=5e-5, weight_decay=1e-4\")\n",
        "\n",
        "        # 6. scheduler 재설정\n",
        "        scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(\n",
        "            optimizer,\n",
        "            mode=\"max\",\n",
        "            factor=0.5,\n",
        "            patience=1\n",
        "        )\n",
        "        print(\"scheduler 재설정 완료\")\n",
        "\n",
        "        phase_changed = True\n",
        "\n",
        "        # phase 전환 직후 early stopping 카운터는 리셋\n",
        "        epochs_no_improve = 0\n",
        "        print(\"Phase 전환으로 epochs_no_improve 초기화\")\n",
        "\n",
        "    # early stopping\n",
        "    if epochs_no_improve >= patience:\n",
        "        print(f\"Early stopping 발생 | Epoch {epoch + 1}\")\n",
        "        break\n",
        "    try:\n",
        "        wandb.log({\n",
        "            \"epoch\": epoch + 1,\n",
        "\n",
        "            \"train/loss\": train_loss,\n",
        "            \"train/acc_top1\": train_acc,\n",
        "            \"train/time_sec\": train_time,\n",
        "\n",
        "            \"val/loss\": val_loss,\n",
        "            \"val/acc_top1\": val_acc,\n",
        "            \"val/acc_top3\": val_top3,\n",
        "            \"val/time_sec\": val_time,\n",
        "\n",
        "            \"diagnostics/overfit_gap\": overfit_gap,\n",
        "            \"optimizer/lr\": current_lr,\n",
        "        })\n",
        "    except Exception as e:\n",
        "        print(\"W&B log 실패:\", e)\n",
        "\n",
        "\n",
        "\n",
        "    # if epochs_no_improve >= patience:\n",
        "    #     print(f\"Early stopping 발생 | Epoch {epoch + 1}\")\n",
        "    #     break\n",
        "\n",
        "class_acc_df = make_class_accuracy_table(\n",
        "    labels = val_labels,\n",
        "    preds = val_preds,\n",
        "    classes= classes\n",
        ")\n",
        "\n",
        "\n",
        "try:\n",
        "    wandb.run.summary[\"best_val_acc\"] = best_val_acc\n",
        "    wandb.run.summary[\"best_epoch\"] = best_epoch\n",
        "    wandb.run.summary[\"final_val_acc\"] = val_acc\n",
        "    wandb.run.summary[\"final_train_acc\"] = train_acc\n",
        "\n",
        "    wandb.log({\n",
        "        \"tables/class_accuracy\": wandb.Table(dataframe=class_acc_df)\n",
        "    })\n",
        "\n",
        "    wandb.finish()\n",
        "\n",
        "except Exception as e:\n",
        "    print(\"W&B finish 실패:\", e)\n",
        "\n",
        "print(\"\\n학습 완료\")\n",
        "print(\"Best Val Acc:\", round(best_val_acc, 4))\n",
        "print(\"Best Epoch:\", best_epoch)\n",
        "print(\"저장 경로:\", save_path)"
      ]
    },
