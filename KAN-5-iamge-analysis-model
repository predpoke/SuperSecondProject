        "    return model\n",
        "\n",
        "  if not isinstance(old_head, nn.Linear):\n",
        "    raise TypeError(f\"예상한 Linear가 아닙니다 : {type(old_head)}\")\n",
        "\n",
        "\n",
        "  in_features = old_head.in_features\n",
        "  out_features = old_head.out_features\n",
        "\n",
        "  new_head = nn.Sequential(\n",
