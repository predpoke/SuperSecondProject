        "        return len(self.df)\n",
        "\n",
        "    def __getitem__(self, idx): # idx 번째 데이터를 꺼내는 함수\n",
        "        row = self.df.iloc[idx]\n",
        "\n",
        "        image_path = row[\"image_path\"]\n",
        "        label = int(row[\"label\"])\n",
        "\n",
